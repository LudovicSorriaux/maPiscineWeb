        .graph-zone-title{text-align:center;margin:0;padding:6px 0;font-size:15px;cursor:pointer}
        .graph-selector{display:none}
        .graph-content{position:relative}
        .graph-canvas{display:block;width:100%;height:220px;min-height:80px}
