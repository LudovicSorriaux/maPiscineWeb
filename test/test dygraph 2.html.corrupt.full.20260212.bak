else { el.style.display='none'; el.style.width='100%'; el.style.height='0px'; }}); } [g1,g2,g3].forEach(g=>{ if(g) try{ g.resize(); }catch(e){} }); try{ applyRangeSelectorToLastVisible(); }catch(e){} }

    function applyRangeSelectorToLastVisible(){ const layout=(function(){const m=getGraphMode(); switch(m){case 'mobile-portrait':return{count:1};case 'mobile-landscape':return{count:2};case 'tablet-portrait':return{count:2};case 'tablet-landscape':return{count:2};case 'desktop-landscape':return{count:3};case 'desktop-portrait':return{count:3};default:return{count:2}}})(); const count=layout.count; const last=count-1; const graphs=[g1,g2,g3]; graphs.forEach((g,idx)=>{ if(!g) return; const should=idx===last; try{ g.updateOptions({ showRangeSelector: should }); g.resize(); }catch(e){ testLog('applyRangeSelector failed',e); }}); setTimeout(()=>{ applyChartHeights(); },120); setTimeout(()=>{ applyChartHeights(); },300); }

    function createOrUpdateGraphs(){ for(let i=1;i<=3;i++){ const $sel=$('#graph-zone-'+i+' .zone-graph-selector'); const graphType=($sel.length?$sel.val():$('#graph-zone-'+i).attr('data-graph-type'))||'chemistry'; populateGraphZone(i,graphType); const $canvas=$('#graph-zone-'+i).find('.graph-canvas'); if($canvas.length) $canvas.attr('id','graph-canvas-'+i).css({position:'relative',width:'100%',height:'100%'}); else { try{ $('#graph-zone-'+i+' .graph-content').append('<div class="graph-canvas" id="graph-canvas-'+i+'" style="position:relative;width:100%;height:160px;min-height:80px"></div>'); testLog('[TEST-DIAG] fallback graph-canvas created for zone',i);}catch(e){ testLog('[TEST-DIAG] fallback create failed',i,e);} } } const el1=document.getElementById('graph-canvas-1'); const el2=document.getElementById('graph-canvas-2'); const el3=document.getElementById('graph-canvas-3'); const missing=[]; if(!el1) missing.push(1); if(!el2) missing.push(2); if(!el3) missing.push(3); if(missing.length){ createAttempt++; testLog('[TEST-DIAG] canvases missing:',missing,'attempt',createAttempt); if(createAttempt<=6){ setTimeout(createOrUpdateGraphs,150+createAttempt*120); return; } else { testLog('[TEST-DIAG] give up after retries, missing:',missing); } } createAttempt=0; if(!g1 && el1){ g1=new Dygraph(el1,data,{ ...commonOptions, labels:['Temps','Pression (Bar)','Inutilisé'], visibility:[true,false], colors:['#3498db'], fillGraph:true, drawXAxis:false, labelsDiv:document.querySelector('#graph-zone-1 .graph-legend'), labelsSeparateLines:false }); testLog('[TEST-DIAG] g1 created',!!g1); } if(!g2 && el2){ g2=new Dygraph(el2,data,{ ...commonOptions, labels:['Temps','Inutilisé','Température (°C)'], visibility:[false,true], colors:['#e74c3c'], showRangeSelector:true, rangeSelectorHeight:30, rangeSelectorPlotStrokeColor:'#c0392b', rangeSelectorPlotFillColor:'rgba(231,76,60,0.3)', labelsDiv:document.querySelector('#graph-zone-2 .graph-legend'), labelsSeparateLines:false, zoomCallback:function(minX,maxX){ try{ if(g1){ g1.updateOptions({ dateWindow:[minX,maxX] }); g1.resize(); } }catch(e){ testLog('zoomCallback sync failed',e);} } }); testLog('[TEST-DIAG] g2 created',!!g2); } if(!g3 && el3){ g3=new Dygraph(el3,data,{ ...commonOptions, labels:['Temps','Pression (Bar)','Température (°C)'], visibility:[true,true], colors:['#3498db','#e74c3c'], showRangeSelector:false, rangeSelectorHeight:30, labelsDiv:document.querySelector('#graph-zone-3 .graph-legend'), labelsSeparateLines:false, zoomCallback:function(minX,maxX){ try{ if(g1) g1.updateOptions({ dateWindow:[minX,maxX] }); if(g2) g2.updateOptions({ dateWindow:[minX,maxX] }); }catch(e){ testLog('zoomCallback g3 sync failed',e);} } }); testLog('[TEST-DIAG] g3 created',!!g3); } try{ const graphs=[g1,g2,g3].filter(Boolean); if(graphs.length>=2){ sync=Dygraph.synchronize(...graphs,{ selection:true, zoom:true, range:true }); testLog('[TEST-DIAG] synchronized graphs count',graphs.length); } else { testLog('[TEST-DIAG] not enough graphs to synchronize',graphs.length); } }catch(e){ testLog('synchronize failed',e); } if(resizeObserver) resizeObserver.disconnect(); resizeObserver=new ResizeObserver(()=>{ applyChartHeights(); }); resizeObserver.observe(document.querySelector('.dashboard-card')); }

    function enableHandlePointerFixes(){ function attach(){ const handles=document.querySelectorAll('.dygraph-rangesel-zoomhandle'); handles.forEach(h=>{ if(h.__patched) return; h.__patched=true; try{ h.style.touchAction='none'; h.addEventListener('pointerdown',ev=>{ ev.stopPropagation(); ev.preventDefault(); try{ h.setPointerCapture(ev.pointerId);}catch(e){} },{passive:false}); h.addEventListener('pointermove',ev=>{ ev.stopPropagation();},{passive:false}); h.addEventListener('pointerup',ev=>{ ev.stopPropagation(); try{ h.releasePointerCapture(ev.pointerId);}catch(e){} },{passive:false}); h.addEventListener('touchstart',ev=>{ ev.stopPropagation();},{passive:false}); }catch(e){} }); } attach(); setTimeout(attach,120); setTimeout(attach,400); }

    $(document).off('click','.graph-zone-title');
    $(document).on('click','.graph-zone-title',function(e){ const $zone=$(this).closest('.graph-zone'); const $axis=$zone.find('.axis-selector'); const $gsel=$zone.find('.graph-selector'); testLog('[TEST-DIAG] title click zone',$zone.attr('id')); if($axis.length){ if($axis.hasClass('open')){ $axis.removeClass('open'); $axis.find('.axis-selector-dropdown').stop(true,true).slideUp(150);}else{ $axis.addClass('open'); $axis.find('.axis-selector-dropdown').stop(true,true).slideDown(150);} } if($gsel.length){ if($gsel.is(':visible')) $gsel.slideUp(150); else $gsel.slideDown(150); } });

    $(document).off('change','.zone-graph-selector');
    $(document).on('change','.zone-graph-selector',function(e){ const zone=$(this).data('zone'); const graphType=$(this).val(); testLog('[TEST-DIAG] zone selector change',zone,graphType); populateGraphZone(zone,graphType); const $canvas=$('#graph-zone-'+zone).find('.graph-canvas'); if($canvas.length) $canvas.attr('id','graph-canvas-'+zone).css({position:'relative',width:'100%',height:'100%'}); try{ if(zone==1 && g1){ if(typeof g1.destroy==='function') g1.destroy(); g1=null;} if(zone==2 && g2){ if(typeof g2.destroy==='function') g2.destroy(); g2=null;} if(zone==3 && g3){ if(typeof g3.destroy==='function') g3.destroy(); g3=null;} }catch(err){ testLog('destroy graph failed',err); } applyChartHeights(); setTimeout(()=>{ createOrUpdateGraphs(); },60); });

    function initCharts(){ for(let i=1;i<=3;i++){ const $sel=$('#graph-zone-'+i+' .zone-graph-selector'); const graphType=($sel.length?$sel.val():$('#graph-zone-'+i).attr('data-graph-type'))||'chemistry'; populateGraphZone(i,graphType); const $canvas=$('#graph-zone-'+i).find('.graph-canvas'); if($canvas.length) $canvas.attr('id','graph-canvas-'+i).css({position:'relative',width:'100%',height:'100%'}); } applyChartHeights(); setTimeout(()=>{ createOrUpdateGraphs(); enableHandlePointerFixes(); setTimeout(()=>{ applyChartHeights(); },120); setTimeout(()=>{ applyChartHeights(); },300); },30); }

    $(document).on('pagebeforeshow', function(){ testLog('[TEST-DIAG] pagebeforeshow'); initCharts(); });
    $(document).ready(function(){ testLog('[TEST-DIAG] ready'); initCharts(); });

    window.__test_charts = { initCharts };

    </script>
    </body>
    </html>
