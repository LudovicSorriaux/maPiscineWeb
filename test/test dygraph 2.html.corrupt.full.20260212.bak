<script>
  // --- 0. NOTE --
  // Ce fichier de test a été adapté pour préparer l'intégration
  // dans l'application (jQuery Mobile + calcul dynamique des hauteurs
  // selon les media queries de l'app). L'initialisation se fait dans
  // `initCharts()` et est déclenchée sur `pagebeforeshow`.

  // --- 1. GÉNÉRATION DE DONNÉES (2 Séries distinctes) ---
  const data = [];
  const t = new Date();
  for (let i = 0; i < 500; i++) {
    const x = new Date(t.getTime() + i * 1000 * 60);
    // Série A : Pression (valeurs ~ 10-20)
    const y1 = 10 + Math.sin(i / 20) * 5 + Math.random(); 
    // Série B : Température (valeurs ~ 200-300)
    const y2 = 200 + Math.cos(i / 20) * 50 + Math.random() * 10;
    data.push([x, y1, y2]);
  }

  // --- 2. CONFIGURATION COMMUNE OPTIMISÉE ---
  const commonOptions = {
    legend: 'always',
    animatedZooms: true,
    gridLineColor: '#eee',
    axisLabelFontSize: 12,
    axisLabelColor: '#666',
    
    // --- C'est ici que la magie de l'alignement opère ---
    // Force la largeur de la zone des étiquettes Y pour que les deux graphes soient alignés verticalement
    yAxisLabelWidth: 60, 
    
    // Formatteur de valeurs pour la légende (2 décimales)
    valueFormatter: (val) => val.toFixed(2),
    
    // Interaction
    highlightCircleSize: 4,
    strokeWidth: 2,
  };

  // --- Diagnostics helper (writes to panel + console) ---
  window.debug = true;
  function testLog(...args) {
    try {
      const s = args.map(a => (typeof a === 'object' ? JSON.stringify(a) : String(a))).join(' ');
      console.log.apply(console, args);
      const panel = document.getElementById('test-diagnostics');
      if (panel) {
        const line = document.createElement('div');
        line.textContent = (new Date()).toLocaleTimeString() + ' - ' + s;
        panel.appendChild(line);
        // keep last 200 lines
        while (panel.childNodes.length > 200) panel.removeChild(panel.firstChild);
        panel.scrollTop = panel.scrollHeight;
      }
    } catch (e) { try { console.log('[TEST-DIAG-ERR]', e); } catch(e){} }
  }

  // createAttempt used to avoid infinite rapid retries when canvases are missing
  let createAttempt = 0;

  // --- 3. INITIALISATION & FONCTIONS D'AIDE ---
  let g1 = null, g2 = null, g3 = null, sync = null;
  let resizeObserver = null;

  // Legacy is* helpers removed: responsive detection centralized in getGraphMode()

  // Copier getGraphMode de l'application pour conserver la même détection responsive
  function getGraphMode() {
    var mqDesktopLandscape = window.matchMedia('(min-width: 1101px) and (orientation: landscape)');
    var mqDesktopPortrait = window.matchMedia('(min-height: 1101px) and (orientation: portrait)');
    var mqTabletPortrait = window.matchMedia('(min-width: 701px) and (max-width: 1100px) and (max-height: 1100px) and (orientation: portrait)');
    var mqTabletLandscape = window.matchMedia('(min-width: 701px) and (max-width: 1100px) and (max-height: 1100px) and (orientation: landscape)');
    var mqMobilePortrait = window.matchMedia('(max-width: 700px) and (orientation: portrait)');
    var mqMobileLandscape = window.matchMedia('(max-height: 700px) and (orientation: landscape)');

    var variant = null;
    if (mqDesktopLandscape.matches) {
      variant = 'desktop-landscape';
    } else if (mqDesktopPortrait.matches) {
      variant = 'desktop-portrait';
    } else if (mqTabletLandscape.matches) {
      variant = 'tablet-landscape';
    } else if (mqTabletPortrait.matches) {
      variant = 'tablet-portrait';
    } else if (mqMobileLandscape.matches) {
      variant = 'mobile-landscape';
    } else if (mqMobilePortrait.matches) {
      variant = 'mobile-portrait';
    } else {
      var width = window.innerWidth;
      var isLandscape = window.innerWidth > window.innerHeight;
      if (width < 768) variant = isLandscape ? 'mobile-landscape' : 'mobile-portrait';
      else if (width < 1024 || !isLandscape) variant = isLandscape ? 'tablet-landscape' : 'tablet-portrait';
      else variant = isLandscape ? 'desktop-landscape' : 'desktop-portrait';
    }

    if (window.debug) console.log('[RESPONSIVE] getGraphMode ->', variant);
    return variant;
  }

  // Templates minimalistes repris de l'application pour injection
  const template = {
    chemistry: `
