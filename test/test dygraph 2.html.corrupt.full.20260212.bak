    // Enhance selects if jQuery Mobile present
    try { $content.enhanceWithin(); } catch(e) {}
    $zone.attr('data-graph-type', graphType);
    var titles = { 'chemistry': "Chimie de l'eau", 'temperature': 'Températures', 'equipment': 'Équipements' };
    $zone.find('.graph-zone-title').text(titles[graversion proprephType] || graphType);
    var $zoneSelector = $zone.find('.zone-graph-selector');
    if ($zoneSelector.length > 0) {
      $zoneSelector.val(graphType);
      try { if ($zoneSelector.data('mobile-selectmenu')) $zoneSelector.selectmenu('refresh'); } catch(e) {}
    }
  }

  // Determine the desired layout based on the canonical getGraphMode mapping
  function determineLayout() {
    const mode = getGraphMode();
    switch (mode) {
      case 'mobile-portrait': return { count: 1, orientation: 'column' };
      case 'mobile-landscape': return { count: 2, orientation: 'row' };
      case 'tablet-portrait': return { count: 2, orientation: 'column' };
      case 'tablet-landscape': return { count: 2, orientation: 'row' };
      case 'desktop-landscape': return { count: 3, orientation: 'row' };
      case 'desktop-portrait': return { count: 3, orientation: 'column' };
      default: return { count: 2, orientation: 'column' };
    }
  }

  // Calcule dynamiquement les hauteurs comme dans l'app (media queries alignées)
  function applyChartHeights() {
    const card = document.querySelector('.dashboard-card');
    const legendBar = document.querySelector('.legend-bar');
    if (!card) return;
    const totalH = card.clientHeight;
    const legendH = legendBar ? legendBar.offsetHeight : 0;
    const gap = 10; // small spacing

    // Compute total height consumed by any visible graph selector controls
    // (we consider their occupied space so sizing in the test is transposable

    // to the app where selectors/titles exist). Only count visible selectors.
    let selectorsTotal = 0;
    try {
      document.querySelectorAll('.graph-selector').forEach(el => {
        // offsetParent null => display:none or not in layout
        if (el && el.offsetParent !== null) selectorsTotal += el.offsetHeight || 0;
